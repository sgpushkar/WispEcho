# ---------- SERVER ----------
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# ---------- DATABASE (Postgres, e.g. Railway/Render/Supabase) ----------
DATABASE_URL="postgresql://user:password@localhost:5432/genz_chat?schema=public"

# ---------- JWT ----------
JWT_ACCESS_SECRET=642c0d937f48dce2b7105c35a8edf51c5f019ef39a56f89d214f69da3540ea7a
JWT_REFRESH_SECRET=023d62b6f922a604c47d306ac6ae9452905d52e39f9204ccc904114557666630
